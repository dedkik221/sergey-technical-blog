---
import { getCollection } from 'astro:content';
import { pathForArticle, formatDate } from '@lib/content';
import { site } from '@lib/site';

const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.datePublished.getTime() - a.data.datePublished.getTime())
  .slice(0, 5);
const feedbackReady = Boolean(site.feedbackEndpoint);
---

<aside class="author-sidebar" data-pagefind-ignore>
  <div class="author-card">
    <img class="author-avatar" src={site.author.avatarImage} alt="" width="96" height="96" loading="lazy" />
    <div>
      <p class="author-kicker">Автор</p>
      <h2>{site.author.name}</h2>
      <p>{site.author.sidebarDescription}</p>
    </div>
  </div>

  <nav class="sidebar-links" aria-label="Ссылки автора">
    <a href="/about/">Обо мне</a>
    <a href="/projects/">Проекты</a>
    <a href={site.author.github}>GitHub</a>
    <a href={site.author.telegram}>Telegram</a>
  </nav>

  <section class="sidebar-section">
    <h3>Последние статьи</h3>
    <ol class="latest-list">
      {
        articles.slice(0, 5).map((article) => (
          <li>
            {
              article.data.draft ? (
                <span>{article.data.title}</span>
              ) : (
                <a href={pathForArticle(article.id)}>{article.data.title}</a>
              )
            }
            <time datetime={article.data.datePublished.toISOString()}>{formatDate(article.data.datePublished)}</time>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="sidebar-section subscribe-box">
    <h3>Подписка на обновления</h3>
    <p>Новые статьи и новости о проекте — без спама.</p>
    <form action={feedbackReady ? site.feedbackEndpoint : undefined} method={feedbackReady ? 'POST' : undefined}>
      <input type="email" name="email" placeholder="Ваш email" autocomplete="email" />
      <button type={feedbackReady ? 'submit' : 'button'}>{feedbackReady ? 'Подписаться' : 'Подписаться'}</button>
    </form>
  </section>

  <p class="sidebar-copy">© {new Date().getFullYear()} {site.author.name}</p>
</aside>
