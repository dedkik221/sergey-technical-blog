---
import { site } from '@lib/site';

const pathname = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
};
---

<header class="site-header" data-pagefind-ignore>
  <div class="shell header-inner">
    <a class="brand" href="/" aria-label="На главную">
      <strong>{site.shortName}</strong>
    </a>

    <nav class="nav" aria-label="Главная навигация">
      {
        site.nav.map((item) => (
          <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="header-actions" aria-label="Быстрые ссылки">
      <a href={site.author.github} aria-label="GitHub">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2.5a9.5 9.5 0 0 0-3 18.52c.48.09.65-.2.65-.46v-1.7c-2.64.57-3.2-1.12-3.2-1.12-.43-1.1-1.05-1.39-1.05-1.39-.86-.59.07-.58.07-.58.95.07 1.45.98 1.45.98.85 1.44 2.22 1.03 2.76.78.09-.62.33-1.03.6-1.27-2.1-.24-4.31-1.05-4.31-4.68 0-1.03.37-1.88.98-2.54-.1-.24-.42-1.2.09-2.5 0 0 .79-.25 2.6.97a8.9 8.9 0 0 1 4.73 0c1.8-1.22 2.6-.97 2.6-.97.5 1.3.18 2.26.09 2.5.61.66.98 1.5.98 2.54 0 3.64-2.22 4.44-4.33 4.67.34.3.64.88.64 1.77v2.64c0 .26.17.56.66.46A9.5 9.5 0 0 0 12 2.5Z" />
        </svg>
      </a>
      <a href={site.author.telegram} aria-label="Telegram">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.55 4.4 3.9 10.83c-1.14.46-1.13 1.1-.2 1.38l4.27 1.33 1.63 5c.2.56.1.78.68.78.44 0 .64-.2.9-.45l2.16-2.1 4.5 3.33c.83.46 1.42.22 1.63-.77L22.4 5.54c.3-1.2-.46-1.75-1.85-1.14Zm-11.9 8.83 9.75-6.15c.49-.3.93-.14.57.18l-8.34 7.52-.33 3.49-1.65-5.04Z" />
        </svg>
      </a>
      <button class="theme-toggle" type="button" aria-label="Переключить тему" data-theme-toggle>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 18a6 6 0 1 1 0-12 6 6 0 0 1 0 12Zm0-1.6a4.4 4.4 0 1 0 0-8.8 4.4 4.4 0 0 0 0 8.8ZM11.2 2h1.6v2.7h-1.6V2Zm0 17.3h1.6V22h-1.6v-2.7ZM2 11.2h2.7v1.6H2v-1.6Zm17.3 0H22v1.6h-2.7v-1.6ZM4.22 5.35l1.13-1.13 1.9 1.9-1.13 1.13-1.9-1.9Zm12.53 12.53 1.13-1.13 1.9 1.9-1.13 1.13-1.9-1.9Zm0-11.76 1.9-1.9 1.13 1.13-1.9 1.9-1.13-1.13ZM4.22 18.65l1.9-1.9 1.13 1.13-1.9 1.9-1.13-1.13Z" />
        </svg>
      </button>
    </div>
  </div>
</header>

<script is:inline>
  const storedTheme = localStorage.getItem('theme');
  if (storedTheme === 'dark') document.documentElement.dataset.theme = 'dark';

  document.querySelector('[data-theme-toggle]')?.addEventListener('click', () => {
    const nextTheme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = nextTheme === 'dark' ? 'dark' : '';
    localStorage.setItem('theme', nextTheme);
  });
</script>
